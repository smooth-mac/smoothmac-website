---
import { products } from '../../data/products';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-semibold text-[var(--text)] hover:opacity-80 transition-opacity">
      <span class="text-lg tracking-tight">smooth-mac</span>
    </a>

    <!-- Nav Links -->
    <nav class="flex items-center gap-6">
      <!-- Products dropdown -->
      <div class="relative group">
        <button
          class="flex items-center gap-1 text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors"
          aria-haspopup="true"
        >
          Products
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:rotate-180">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 origin-top scale-95 group-hover:scale-100"
        >
          <div class="glass rounded-xl p-2 shadow-xl">
            {products.map((product) => (
              <a
                href={`/${product.slug}`}
                class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-white/10 transition-colors"
              >
                <div
                  class="w-8 h-8 rounded-lg flex items-center justify-center text-sm"
                  style={`background-color: ${product.accentColor}20; color: ${product.accentColor}`}
                >
                  {product.name[0]}
                </div>
                <div>
                  <div class="text-sm font-medium text-[var(--text)]">{product.name}</div>
                  <div class="text-xs text-[var(--text-secondary)]">{product.tagline}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href="/support" class="text-sm text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors">
        Support
      </a>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="w-9 h-9 flex items-center justify-center rounded-lg text-[var(--text-secondary)] hover:text-[var(--text)] hover:bg-[var(--surface-raised)] transition-colors"
        aria-label="Toggle theme"
      >
        <!-- Sun: shown in dark mode (click to switch to light) -->
        <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon: shown in light mode (click to switch to dark) -->
        <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const themeToggle = document.getElementById('theme-toggle')!;
  const iconSun = document.getElementById('icon-sun')!;
  const iconMoon = document.getElementById('icon-moon')!;

  // ── Navbar scroll ──────────────────────────────────────────────
  function updateNavbar() {
    navbar.classList.toggle('navbar-scrolled', window.scrollY > 20);
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // ── Theme ──────────────────────────────────────────────────────
  function getEffectiveTheme(): 'dark' | 'light' {
    const stored = localStorage.getItem('smoothmac-theme');
    if (stored === 'dark' || stored === 'light') return stored;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyIcon(theme: 'dark' | 'light') {
    iconSun.classList.toggle('hidden', theme === 'light');
    iconMoon.classList.toggle('hidden', theme === 'dark');
  }

  function toggleTheme() {
    const next = getEffectiveTheme() === 'dark' ? 'light' : 'dark';
    localStorage.setItem('smoothmac-theme', next);
    document.documentElement.setAttribute('data-theme', next);
    applyIcon(next);
  }

  // Init icon
  applyIcon(getEffectiveTheme());

  themeToggle.addEventListener('click', toggleTheme);

  // Keep in sync if system preference changes and no override set
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (!localStorage.getItem('smoothmac-theme')) {
      applyIcon(getEffectiveTheme());
    }
  });
</script>

<style>
  #navbar {
    background: transparent;
  }

  #navbar.navbar-scrolled {
    background: rgba(var(--bg-rgb, 250, 250, 250), 0.8);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--border);
  }
</style>
