---
interface Props {
  url: string;
  accentColor?: string;
  size?: 'sm' | 'md' | 'lg';
  label?: string;
}

const { url, accentColor = '#5b8af0', size = 'md', label = 'Download on the App Store' } = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    'inline-flex items-center gap-2 rounded-xl font-semibold text-white',
    'transition-all duration-200 hover:opacity-90 hover:shadow-lg hover:-translate-y-0.5',
    sizeClasses[size],
  ]}
  style={`background-color: ${accentColor}`}
>
  <!-- App Store SVG icon -->
  <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M10 0C4.477 0 0 4.477 0 10s4.477 10 10 10 10-4.477 10-10S15.523 0 10 0zm3.586 14.198L10 10.612l-3.586 3.586-1.414-1.414L8.586 9.2 5 5.614l1.414-1.414L10 7.786l3.586-3.586L15 5.614 11.414 9.2l3.586 3.584-1.414 1.414z"/>
  </svg>
  {label}
</a>
