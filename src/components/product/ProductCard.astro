---
import type { Product } from '../../data/products';
import { formatPrice } from '../../lib/utils';

interface Props {
  product: Product;
  class?: string;
}

const { product, class: className } = Astro.props;
---

<article
  class:list={[
    'group relative flex flex-col rounded-2xl border border-[var(--border)] bg-[var(--surface)] overflow-hidden',
    'hover:shadow-2xl hover:-translate-y-1 transition-all duration-300',
    className,
  ]}
  style={`border-top: 3px solid ${product.accentColor};`}
>
  <!-- Header -->
  <div class="p-6 pb-4 flex items-center gap-4">
    <!-- App icon placeholder -->
    <div
      class="w-14 h-14 rounded-2xl flex items-center justify-center text-2xl font-bold shrink-0"
      style={`background-color: ${product.accentColor}20; color: ${product.accentColor}`}
    >
      {product.name[6] ?? product.name[0]}
    </div>
    <div>
      <h3 class="font-semibold text-[var(--text)] text-lg leading-tight">{product.name}</h3>
      <p class="text-sm text-[var(--text-secondary)] mt-0.5">{product.tagline}</p>
    </div>
  </div>

  <!-- Screenshot placeholder -->
  <div
    class="mx-4 rounded-xl overflow-hidden aspect-video flex items-center justify-center text-sm text-[var(--text-secondary)]"
    style={`background-color: ${product.accentColor}08; border: 1px solid ${product.accentColor}20`}
  >
    <div class="text-center opacity-60">
      <div class="text-3xl mb-2">{product.name[0]}</div>
      <div class="text-xs">{product.name} screenshot</div>
    </div>
  </div>

  <!-- Footer -->
  <div class="p-6 pt-4 flex items-center justify-between mt-auto">
    <!-- Price -->
    <div>
      <span
        class="text-xs font-semibold px-2 py-0.5 rounded-full"
        style={`background-color: ${product.accentColor}15; color: ${product.accentColor}`}
      >
        {formatPrice(product.price)}
      </span>
      <p class="text-xs text-[var(--text-secondary)] mt-1">{product.macosRequirement}</p>
    </div>

    <!-- CTAs -->
    <div class="flex items-center gap-2">
      <a
        href={`/${product.slug}`}
        class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors px-3 py-1.5"
      >
        Learn more
      </a>
      <a
        href={product.appStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium px-4 py-1.5 rounded-lg transition-all duration-200 hover:opacity-90 hover:shadow-md"
        style={`background-color: ${product.accentColor}; color: white`}
      >
        App Store
      </a>
    </div>
  </div>
</article>
