---
import SEOHead from '../components/layout/SEOHead.astro';
import NavBar from '../components/layout/NavBar.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, ogImage, schema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Prevent FOUC: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('smoothmac-theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      schema={schema}
    />
  </head>
  <body class="min-h-screen">
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
