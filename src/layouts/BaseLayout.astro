---
import SEOHead from '../components/layout/SEOHead.astro';
import NavBar from '../components/layout/NavBar.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';
import type { Locale } from '../i18n/types';
import type { AlternateLink } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: object;
  locale?: Locale;
  alternates?: AlternateLink[];
}

const { title, description, ogImage, schema, locale = 'en', alternates } = Astro.props;
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-Hans' : locale}>
  <head>
    <!-- Prevent FOUC: apply stored theme before first paint -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('smoothmac-theme');
        if (t === 'dark' || t === 'light') {
          document.documentElement.setAttribute('data-theme', t);
        }
      })();
    </script>
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      schema={schema}
      alternates={alternates}
    />
  </head>
  <body class="min-h-screen">
    <NavBar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
