---
import BaseLayout from './BaseLayout.astro';
import type { Product } from '../data/products';
import type { Locale } from '../i18n/types';
import { getTranslations, getAlternateLinks } from '../i18n/index';

interface Props {
  product: Product;
  locale?: Locale;
}

const { product, locale = 'en' } = Astro.props;
const t = getTranslations(locale);
const pt = t.products[product.slug as 'smoothsnap' | 'smoothpeek'];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: product.name,
  description: pt.description,
  operatingSystem: product.macosRequirement,
  applicationCategory: 'UtilitiesApplication',
  softwareVersion: product.version,
  offers: {
    '@type': 'Offer',
    price: product.price === 'free' ? '0' : product.price.toString(),
    priceCurrency: 'USD',
  },
  url: `https://smoothmac.app/${product.slug}`,
};

const alternates = getAlternateLinks(`/${product.slug}`, Astro.site?.toString() ?? 'https://smoothmac.app');
---

<BaseLayout
  title={pt.seo.title}
  description={pt.seo.description}
  ogImage={`/products/${product.slug}/hero.png`}
  schema={schema}
  locale={locale}
  alternates={alternates}
>
  <slot />
</BaseLayout>
