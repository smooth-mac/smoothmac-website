---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — smooth-mac"
  description="This page does not exist."
>
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-6">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--text-secondary)] mb-4">404</p>
    <h1 class="text-4xl font-bold text-[var(--text)] mb-4">Page not found.</h1>
    <p class="text-[var(--text-secondary)] mb-8">That page doesn't exist — but our apps do.</p>
    <a
      href="/"
      class="px-6 py-3 rounded-xl font-medium text-white transition-all hover:opacity-90"
      style="background-color: #5b8af0"
    >
      Go home
    </a>
  </div>
</BaseLayout>
