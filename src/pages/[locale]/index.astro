---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/home/HeroSection.astro';
import ProductShowcase from '../../components/home/ProductShowcase.astro';
import { getTranslations, getAlternateLinks, nonDefaultLocales } from '../../i18n/index';
import type { Locale } from '../../i18n/types';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = getTranslations(locale);
const alternates = getAlternateLinks('/', Astro.site?.toString() ?? 'https://smoothmac.app');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'smooth-mac',
  url: 'https://smoothmac.app',
  description: t.home.seo.description,
};
---

<BaseLayout
  title={t.home.seo.title}
  description={t.home.seo.description}
  schema={schema}
  locale={locale}
  alternates={alternates}
>
  <HeroSection locale={locale} />
  <ProductShowcase locale={locale} />

  <!-- Studio Values -->
  <section class="max-w-6xl mx-auto px-6 py-20 border-t border-[var(--border)]">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {t.home.values.map((value) => (
        <div class="reveal">
          <h3 class="font-semibold text-[var(--text)] mb-3">{value.title}</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{value.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- App Store CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <p class="text-sm text-[var(--text-secondary)] mb-3 reveal">
      {t.home.cta.appStoreText}
    </p>
    <p class="text-xs text-[var(--text-secondary)] opacity-60 reveal">
      {t.home.cta.requiresText}
    </p>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>
