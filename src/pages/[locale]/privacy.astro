---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getAlternateLinks, nonDefaultLocales } from '../../i18n/index';
import type { Locale } from '../../i18n/types';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = getTranslations(locale);
const alternates = getAlternateLinks('/privacy', Astro.site?.toString() ?? 'https://smoothmac.app');
---

<BaseLayout
  title={t.privacy.seo.title}
  description={t.privacy.seo.description}
  locale={locale}
  alternates={alternates}
>
  <div class="max-w-2xl mx-auto px-6 pt-32 pb-20">
    <h1 class="text-3xl font-bold text-[var(--text)] mb-8">{t.privacy.headline}</h1>

    <div class="prose prose-sm text-[var(--text-secondary)] space-y-6">
      <p class="text-[var(--text)]">
        <strong>{t.privacy.shortVersion}</strong>
      </p>

      {t.privacy.sections.map((section, i) => (
        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-2">{section.title}</h2>
          {i === 4 ? (
            <p>
              {section.body}{' '}
              <a href="mailto:support@smoothmac.app" class="text-[var(--accent)] hover:underline">
                support@smoothmac.app
              </a>
            </p>
          ) : (
            <p>{section.body}</p>
          )}
        </section>
      ))}

      <p class="text-xs text-[var(--text-secondary)] opacity-60">{t.privacy.lastUpdated}</p>
    </div>
  </div>
</BaseLayout>
