---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products';
import { getTranslations, getAlternateLinks, nonDefaultLocales } from '../../i18n/index';
import type { Locale } from '../../i18n/types';

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
const t = getTranslations(locale);
const alternates = getAlternateLinks('/support', Astro.site?.toString() ?? 'https://smoothmac.app');
---

<BaseLayout
  title={t.support.seo.title}
  description={t.support.seo.description}
  locale={locale}
  alternates={alternates}
>
  <div class="max-w-2xl mx-auto px-6 pt-32 pb-20">
    <h1 class="text-3xl font-bold text-[var(--text)] mb-3">{t.support.headline}</h1>
    <p class="text-[var(--text-secondary)] mb-12">
      {t.support.subheadline}
    </p>

    <!-- Product selector -->
    <div class="flex gap-3 mb-10">
      {products.map((p) => (
        <a
          href={`#${p.slug}`}
          class="px-4 py-2 rounded-lg text-sm font-medium border border-[var(--border)] text-[var(--text-secondary)] hover:text-[var(--text)] hover:border-opacity-60 transition-all"
        >
          {p.name}
        </a>
      ))}
    </div>

    <!-- SmoothSnap FAQ -->
    <section id="smoothsnap" class="mb-12">
      <h2 class="text-xl font-semibold text-[var(--text)] mb-6 flex items-center gap-2">
        <span class="w-6 h-6 rounded-md text-xs flex items-center justify-center font-bold" style="background: #34c75920; color: #34c759">S</span>
        SmoothSnap
      </h2>
      <div class="space-y-6">
        {t.support.smoothsnap.faqs.map(({ q, a }) => (
          <div>
            <h3 class="font-medium text-[var(--text)] mb-1">{q}</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- SmoothPeek FAQ -->
    <section id="smoothpeek" class="mb-12">
      <h2 class="text-xl font-semibold text-[var(--text)] mb-6 flex items-center gap-2">
        <span class="w-6 h-6 rounded-md text-xs flex items-center justify-center font-bold" style="background: #ff9f0a20; color: #ff9f0a">P</span>
        SmoothPeek
      </h2>
      <div class="space-y-6">
        {t.support.smoothpeek.faqs.map(({ q, a }) => (
          <div>
            <h3 class="font-medium text-[var(--text)] mb-1">{q}</h3>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Contact -->
    <section class="p-6 rounded-2xl border border-[var(--border)] bg-[var(--surface)]">
      <h2 class="font-semibold text-[var(--text)] mb-2">{t.support.contact.headline}</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">
        {t.support.contact.subtext}
      </p>
      <a
        href="mailto:support@smoothmac.app"
        class="text-sm font-medium text-[var(--accent)] hover:underline"
      >
        {t.support.contact.emailLabel}
      </a>
    </section>
  </div>
</BaseLayout>
